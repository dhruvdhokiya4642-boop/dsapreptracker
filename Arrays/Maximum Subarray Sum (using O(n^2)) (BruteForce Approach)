#include <iostream>
#include <vector>
#include <climits>
#include <algorithm>
using namespace std;

int BruteForce(int arr[], int n){
    int maxSum = INT16_MIN;
    for(int st = 0 ; st<n ; st++){
        int currentSum=0;
        for(int end = st ; end <n ; end++){
            currentSum+=arr[end];
            maxSum = max(currentSum,maxSum);
        }
    }
    return maxSum;
}
int main(){
    int n;
    cin >> n;
    int arr[n];
    for(int i = 0 ; i < n ; i++){
        cin >> arr[i];
    }
    int res = BruteForce(arr,n);
    cout << res;
}
