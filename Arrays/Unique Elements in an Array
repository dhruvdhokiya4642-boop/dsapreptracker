#include <iostream>
using namespace std;

int UniqVal(int arr[], int n){
    
    for (int i=0 ; i<n;i++){
        int count = 0;
        for(int j=0;j<n;j++){
            if(i!=j && arr[i]!=arr[j]){
                
                    count++;
                
            }
        }
        if(count == n-1){
            cout << arr[i] << " ";
            
        }
    }
}
int main(){
    int n;
    cout << "Enter number of elements: ";
    cin >> n;
    int arr[n];

    for(int i = 0 ; i<n;i++){
    cout << "E " << i+1 << ": ";
    cin >> arr[i];
}
cout << "Unique Elements:\n";
UniqVal(arr,n);
}
